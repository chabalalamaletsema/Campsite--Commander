<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_splash.xml  –  Splash Screen layout
    Dark forest-green background with centred logo and title.
    Auto-transitions to MainActivity after 3000ms via SplashActivity.kt.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_forest_gradient"
    android:padding="32dp">

    <!-- Campfire logo emoji -->
    <TextView
        android:id="@+id/tvSplashLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔥"
        android:textSize="96sp"
        android:layout_marginBottom="16dp"/>

    <!-- App name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Campsite Commander"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#F0FFF0"
        android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp"/>

    <!-- Tagline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pack smart. Camp better."
        android:textSize="16sp"
        android:textColor="#A8D5A2"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <!-- Loading indicator text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Setting up base camp…"
        android:textSize="13sp"
        android:textColor="#6B9E65"
        android:gravity="center"/>

</LinearLayout>
